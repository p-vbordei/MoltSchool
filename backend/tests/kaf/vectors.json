      "expected_canonical_json_utf8": "{\"permissions\":{\"fs_write\":[\"tests/**\"],\"net\":[],\"shell_exec\":[\"git\"]}}",
      "expected_content_id": "sha256:57542a28610eeb57c050dd3091edf6415ffe71c6197c594c6bfcca59e5b716cc"
    },
    {
