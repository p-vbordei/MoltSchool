{
  "version": "0.1",
  "vectors": [
    {
      "id": "v1",
      "description": "empty dict -> canonical {}",
      "input_type": "dict",
      "input": {},
      "expected_canonical_json_hex": "7b7d",
      "expected_canonical_json_utf8": "{}",
      "expected_content_id": "sha256:44136fa355b3678a1146ad16f7e8649e94fb4fc21fe77e8310c060f61caaff8a"
    },
    {
      "id": "v2",
      "description": "two keys, already sorted",
      "input_type": "dict",
      "input": {
        "a": 1,
        "b": 2
      },
      "expected_canonical_json_hex": "7b2261223a312c2262223a327d",
      "expected_canonical_json_utf8": "{\"a\":1,\"b\":2}",
      "expected_content_id": "sha256:43258cff783fe7036d8a43033f830adfc60ec037382473548ac742b888292777"
    },
    {
      "id": "v3",
      "description": "same keys, unsorted input",
      "input_type": "dict",
      "input": {
        "b": 2,
        "a": 1
      },
      "expected_canonical_json_hex": "7b2261223a312c2262223a327d",
      "expected_canonical_json_utf8": "{\"a\":1,\"b\":2}",
      "expected_content_id": "sha256:43258cff783fe7036d8a43033f830adfc60ec037382473548ac742b888292777"
    },
    {
      "id": "v4",
      "description": "nested dict with array and sub-dict",
      "input_type": "dict",
      "input": {
        "x": [
          3,
          1,
          2
        ],
        "y": {
          "b": 1,
          "a": 2
        }
      },
      "expected_canonical_json_hex": "7b2278223a5b332c312c325d2c2279223a7b2261223a322c2262223a317d7d",
      "expected_canonical_json_utf8": "{\"x\":[3,1,2],\"y\":{\"a\":2,\"b\":1}}",
      "expected_content_id": "sha256:45ac223e0380e306b0cdda0fe1ddb6770ce35be66fd793f11fecc66a5b26f23e"
    },
    {
      "id": "v5",
      "description": "content_id over b'hello world'",
      "input_type": "bytes",
      "input": "hex:68656c6c6f20776f726c64",
      "expected_content_id": "sha256:b94d27b9934d3e08a52e52d7da7dabfac484efe37a5380ee9088f7ace2efcde9"
    },
    {
      "id": "v6",
      "description": "targets list (additive KAF field, §3.3) - canonical bytes stable",
      "input_type": "dict",
      "input": {
        "targets": [
          "claude-code",
          "mcp-generic"
        ]
