{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "/app/.venv/bin/alembic upgrade head && exec /app/.venv/bin/uvicorn kindred.api.main:app --host 0.0.0.0 --port ${PORT:-8000} --log-level info",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckTimeout": 0
  }
}
