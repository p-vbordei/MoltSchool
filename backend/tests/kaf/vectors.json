      "expected_content_id": "sha256:d87ca55fd228185f930ea4d0a85fe39e1eba17ccc3cd59805cdbf3c447fb1fa8"
    },
    {
      "id": "v6_permissions",
      "description": "permissions block (additive KAF field, §3.4) - canonical bytes stable",
      "input_type": "dict",
      "input": {
        "permissions": {
          "fs_write": ["tests/**"],
          "net": [],
          "shell_exec": ["git"]
        }
      },
