      "input": {
        "b": 2,
        "a": 1
      },
      "expected_canonical_json_hex": "7b2261223a312c2262223a327d",
      "expected_canonical_json_utf8": "{\"a\":1,\"b\":2}",
      "expected_content_id": "sha256:43258cff783fe7036d8a43033f830adfc60ec037382473548ac742b888292777"
    },
    {
      "id": "v4",
